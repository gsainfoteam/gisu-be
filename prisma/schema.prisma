generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Course {
  id       Int       @id @default(autoincrement())
  code     String    @unique
  title    String
  type     String
  credit   Int
  sections Section[]
}

model Section {
  id            Int          @id @default(autoincrement())
  sectionNo     String
  instructor    String
  maxCapacity   Int
  currentSeats  Int          @default(0)
  timetableText String?
  timeSlots     TimeSlot[]

  courseId      Int
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments   Enrollment[]

  @@unique([courseId, sectionNo])
}

model TimeSlot {
  id        Int     @id @default(autoincrement())
  slotCode  String

  sectionId Int
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, slotCode])
}

model User {
  id          Int          @id @default(autoincrement())
  token       String       @unique
  enrollments Enrollment[]
}

model Enrollment {
  id        Int     @id @default(autoincrement())

  userId    Int
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  sectionId Int
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([userId, sectionId])
}